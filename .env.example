# ──────────────────────────────────────────────
# Copy this file to `.env.local` (development) or set these in your
# Hostinger hPanel → Node.js app → Environment variables (production),
# then fill in real values. Do NOT commit the filled-in file.
# ──────────────────────────────────────────────

# MySQL connection (create the database + user in hPanel → Databases → MySQL).
# On Hostinger shared hosting the DB runs on the same host as the app, so the
# host is usually "localhost". The username/database are prefixed (e.g. u123456_qr).
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=your_db_name
# Keep this low — shared hosting limits concurrent connections.
MYSQL_CONNECTION_LIMIT=5

# Secret used to sign auth JWTs. Use a long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-to-a-long-random-secret

# Registration is invite-only: only people who enter this exact code on the
# /register page can create an account. Share it only with your team. Leave it
# UNSET to disable new sign-ups entirely (existing users can still log in).
# Use a long random value, e.g. `openssl rand -hex 16`.
SIGNUP_INVITE_CODE=change-me-to-a-shared-invite-code

# Public base URL of the deployed site (used to build QR redirect links).
# No trailing slash. e.g. https://your-domain.com
BASE_URL=http://localhost:3000
